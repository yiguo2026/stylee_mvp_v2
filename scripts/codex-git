#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
GIT_BIN="${CODEX_GIT_BIN:-/usr/bin/git}"
GH_BIN="${CODEX_GH_BIN:-/opt/homebrew/bin/gh}"
GH_CONFIG_DIR="${CODEX_GH_CONFIG_DIR:-$ROOT_DIR/.codex-private/github}"

mkdir -p "$GH_CONFIG_DIR"
chmod 700 "$ROOT_DIR/.codex-private" "$GH_CONFIG_DIR"

# Apply the Codex credential helper to this invocation only. This deliberately
# avoids `gh auth setup-git`, repository-local credential config, shell profile
# edits, and global Git config, so Claude Code keeps its existing Git path.
HELPER="!f() { GH_CONFIG_DIR='$GH_CONFIG_DIR' '$GH_BIN' auth git-credential \"\$@\"; }; f"
export GIT_TERMINAL_PROMPT="${GIT_TERMINAL_PROMPT:-0}"

exec "$GIT_BIN" \
  -c credential.helper= \
  -c "credential.https://github.com.helper=$HELPER" \
  "$@"
