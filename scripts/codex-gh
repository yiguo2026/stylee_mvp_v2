#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
GH_BIN="${CODEX_GH_BIN:-/opt/homebrew/bin/gh}"
export GH_CONFIG_DIR="${CODEX_GH_CONFIG_DIR:-$ROOT_DIR/.codex-private/github}"

mkdir -p "$GH_CONFIG_DIR"
chmod 700 "$ROOT_DIR/.codex-private" "$GH_CONFIG_DIR"

exec "$GH_BIN" "$@"
