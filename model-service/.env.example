# Server-only secrets. Never prefix these with EXPO_PUBLIC_ and never commit .env.
DEEPSEEK_API_KEY=replace-me
DASHSCOPE_API_KEY=replace-me
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace-me
SUPABASE_SECRET_KEY=sb_secret_replace-me

# Required for a public deployment. Comma-separated exact origins.
STYLEE_ALLOWED_ORIGINS=https://yiguo2026.github.io
STYLEE_REQUIRE_AUTH=true
STYLEE_RATE_LIMIT_PER_MINUTE=20
LLM_MAX_TOKENS=2048

# Optional separate usage-monitoring project. Leave unset to disable remote usage uploads.
# STYLEE_SUPABASE_URL=https://usage-project.supabase.co
# STYLEE_SUPABASE_KEY=sb_publishable_replace-me
