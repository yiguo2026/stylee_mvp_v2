# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Model service URL. DeepSeek/Qwen keys belong to that server, never in Expo env.
EXPO_PUBLIC_STYLEE_API=http://127.0.0.1:8000

# QWeather API (Optional)
EXPO_PUBLIC_QWEATHER_KEY=your-qweather-key
EXPO_PUBLIC_QWEATHER_HOST=devapi.qweather.com

# AI 用量埋点：可选。不设会自动用『设备名 + 登录账号』识别，同伴无需任何配置。
# 只有想用自定义显示名时才设。
# EXPO_PUBLIC_DEV_TAG=your-name

# AI 用量监控库(可选覆盖;默认已内置指向监控专用 Supabase)
# EXPO_PUBLIC_USAGE_SUPABASE_URL=https://xxx.supabase.co
# EXPO_PUBLIC_USAGE_SUPABASE_KEY=sb_publishable_xxx
