# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_SUPABASE_SERVICE_KEY=your-service-key

# DeepSeek API
EXPO_PUBLIC_DEEPSEEK_KEY=your-deepseek-key
EXPO_PUBLIC_DEEPSEEK_HOST=api.deepseek.com

# DashScope API — Qwen VL vision + Qwen Image generation
EXPO_PUBLIC_DASHSCOPE_API_KEY=your-dashscope-api-key

# QWeather API (Optional)
EXPO_PUBLIC_QWEATHER_KEY=your-qweather-key
EXPO_PUBLIC_QWEATHER_HOST=devapi.qweather.com

# AI 用量埋点：可选。不设会自动用『设备名 + 登录账号』识别，同伴无需任何配置。
# 只有想用自定义显示名时才设。
# EXPO_PUBLIC_DEV_TAG=your-name
